from .config import Config

_config = None
_debug = False
_quiet = False


def config():
    global _config
    if _config is None:
        _config = Config()
    return _config


def enable_debug():
    global _debug
    _debug = True


def is_debug():
    return _debug


def enable_quiet():
    global _quiet
    _quiet = True


def disable_quiet():
    global _quiet
    _quiet = False


def is_quiet():
    return _quiet
