### `backends/gemini.py`: `parse_response` + `_assistant_parts`

Ruby's `response.dig("candidates", 0, "content", "parts")` safely no-ops
through any missing level of nesting. Python has no built-in `dig` —
translated with `.get(...) or {}`/`or []` chaining rather than writing a
dedicated dig helper (same "not every Ruby line needs a literal Python
counterpart" reasoning as `02_the_registry`'s `transform_keys` gap):

```python
def parse_response(self, response):
    candidates = response.get("candidates") or []
    first = candidates[0] if candidates else {}
    parts = (first.get("content") or {}).get("parts") or []

    content = []
    tool_used = False
    for part in parts:
        if part.get("functionCall"):
            fc = part["functionCall"]
            content.append({"type": "tool_use", "id": fc["name"], "name": fc["name"], "input": fc.get("args") or {}})
            tool_used = True
        elif part.get("text"):
            content.append({"type": "text", "text": part["text"]})

    return {"stop_reason": "tool_use" if tool_used else "end_turn", "content": content}

def _assistant_parts(self, content):
    blocks = [{"type": "text", "text": content}] if isinstance(content, str) else content
    result = []
    for b in blocks:
        if b.get("type") == "tool_use":
            result.append({"functionCall": {"name": b["name"], "args": b["input"]}})
        else:
            result.append({"text": b["text"]})
    return result
```

`to_messages`'s `:assistant` case becomes:
`result.append({"role": "model", "parts": self._assistant_parts(msg.content)})`.

### `backends/ollama.py` and `ollama_cloud.py`: `parse_response` + `_assistant_message`

Identical shape for both (they only differ in constructor/headers/url,
already ported):

```python
def parse_response(self, response):
    message = response.get("message") or {}
    tool_calls = message.get("tool_calls") or []

    content = []
    if message.get("content"):
        content.append({"type": "text", "text": message["content"]})

    for tc in tool_calls:
        fn = tc.get("function") or {}
        content.append({"type": "tool_use", "id": fn.get("name"), "name": fn.get("name"), "input": fn.get("arguments") or {}})

    return {"stop_reason": "end_turn" if not tool_calls else "tool_use", "content": content}

def _assistant_message(self, content):
    blocks = [{"type": "text", "text": content}] if isinstance(content, str) else content
    text_blocks = [b for b in blocks if b.get("type") == "text"]
    tool_blocks = [b for b in blocks if b.get("type") == "tool_use"]

    message = {"role": "assistant", "content": "".join(b["text"] for b in text_blocks)}
    if tool_blocks:
        message["tool_calls"] = [{"function": {"name": b["name"], "arguments": b["input"]}} for b in tool_blocks]
    return message
```

`to_messages`'s `:assistant` case: `conversation.append(self._assistant_message(msg.content))`.

### `backends/openai.py`: `parse_response` (with `json.loads`) + `_assistant_message` (with `json.dumps`)

OpenAI is the one backend whose tool-call arguments arrive as a
JSON-*encoded string*, not a structured object — needs `import json`
(matching Ruby's `require "json"` at the top of `openai.rb`):

```python
import json

...

def parse_response(self, response):
    choices = response.get("choices") or []
    message = (choices[0].get("message") if choices else {}) or {}
    tool_calls = message.get("tool_calls") or []

    content = []
    if message.get("content"):
        content.append({"type": "text", "text": message["content"]})

    for tc in tool_calls:
        function = tc.get("function") or {}
        content.append({
            "type": "tool_use",
            "id": tc.get("id"),
            "name": function.get("name"),
            "input": json.loads(function.get("arguments") or "{}"),
        })

    return {"stop_reason": "end_turn" if not tool_calls else "tool_use", "content": content}

def _assistant_message(self, content):
    blocks = [{"type": "text", "text": content}] if isinstance(content, str) else content
    text_blocks = [b for b in blocks if b.get("type") == "text"]
    tool_blocks = [b for b in blocks if b.get("type") == "tool_use"]

    message = {"role": "assistant", "content": "".join(b["text"] for b in text_blocks)}
    if tool_blocks:
        message["tool_calls"] = [
            {"id": b["id"], "type": "function", "function": {"name": b["name"], "arguments": json.dumps(b["input"])}}
            for b in tool_blocks
        ]
    return message
