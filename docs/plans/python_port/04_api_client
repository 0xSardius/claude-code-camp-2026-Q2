@classmethod
def _fetch(cls, settings: dict, key: Any) -> Any:
    # Ruby (04_api_client): `return nil unless settings.is_a?(Hash)` --
    # guards against settings being None (e.g. config.tasks("nonexistent")
    # resolves to None), so provider()/model() raise their own clear
    # "required in settings.yaml" error instead of a confusing
    # AttributeError from calling .get on None. Supersedes this method's
    # previous docstring note (03_prompt_builder and earlier), which
    # documented the OLD Ruby behavior (raising NoMethodError on a nil
    # settings) as something deliberately mirrored -- that's no longer
    # true of the Ruby source as of this step, so mirror the new behavior
    # instead of the stale comment.
    if not isinstance(settings, dict):
        return None
    return settings.get(str(key))
