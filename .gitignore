# Windows Zone.Identifier files (WSL download metadata)
*:Zone.Identifier

# Environment / secrets
.env
.env.local

node_modules/

week0_explore/preview/data/world/

# Boukensha personal runtime config (credentials + local settings/prompt
# overrides) - only the placeholder is tracked, see week1_baseline/ruby/00_config
.boukensha/*
!.boukensha/.keep

# Ruby: gitignore lockfiles for gems/libraries (let consumers resolve their
# own dependency versions) - applies to week1_baseline/ruby and any future
# Ruby steps
Gemfile.lock

# Ruby: locally-vendored gems (bundle config set --local path 'vendor/bundle')
# and bundler's own local config, so no sudo is needed for `bundle install`.
# **/ prefix so this matches at any depth (e.g. week1_baseline/ruby/00_config/vendor/bundle),
# not just a vendor/bundle at the repo root.
**/vendor/bundle/
.bundle/
